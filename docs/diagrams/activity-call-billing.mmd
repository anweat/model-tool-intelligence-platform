flowchart TD
  A["选择供应商"] --> B["选择可用模型"]
  B --> C["填写工具名称、Token 和耗时"]
  C --> D{"调用是否成功"}
  D -->|"否"| E["记录失败原因"]
  D -->|"是"| F{"是否缓存命中"}
  F -->|"是"| G["按缓存折扣计算输入 Token 费用"]
  F -->|"否"| H["按完整输入 Token 计算费用"]
  E --> I["保存调用记录"]
  G --> J["计算输出 Token 费用"]
  H --> J
  J --> I
  I --> K["更新缓存命中率"]
  K --> L["更新 Token 与费用汇总"]
  L --> M{"是否超过预算阈值"}
  M -->|"是"| N["显示预算告警"]
  M -->|"否"| O["显示正常状态"]
